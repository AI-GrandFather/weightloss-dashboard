# Server-only values. Configure these in Vercel; never commit real credentials.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
GROQ_API_KEY=gsk_replace_me
SHARED_SECRET=replace-with-a-long-random-passphrase

# Optional OpenAI-compatible LiteLLM proxy. When omitted, Groq is called directly.
# LITELLM_BASE_URL=https://your-litellm-proxy.example.com/v1
# LITELLM_API_KEY=sk-replace-me
# LITELLM_MODEL=groq/llama-3.3-70b-versatile
